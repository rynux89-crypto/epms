<?xml version="1.0" encoding="UTF-8"?>
<Context>
  <Resource
      name="jdbc/ups"
      auth="Container"
      type="javax.sql.DataSource"
      driverClassName="com.microsoft.sqlserver.jdbc.SQLServerDriver"
      url="jdbc:sqlserver://localhost:1433;databaseName=UPS_MONITOR;encrypt=true;trustServerCertificate=true;charset=UTF-8"
      username="UPS_DB_USER"
      password="UPS_DB_PASSWORD"
      maxTotal="30"
      maxIdle="10"
      minIdle="2"
      maxWaitMillis="8000"
      validationQuery="SELECT 1"
      testOnBorrow="true"
      testWhileIdle="true"
      timeBetweenEvictionRunsMillis="30000"
      minEvictableIdleTimeMillis="300000"
      removeAbandonedOnBorrow="true"
      removeAbandonedTimeout="60"
      logAbandoned="true" />
</Context>

<section class="kpis">
            <a class="panel kpi kpi-link" href="monitoring/ups_overview.jsp" title="전체 UPS 현황 보기"><div class="kpi-icon">✓</div><div><h3>전체 상태</h3><div class="kpi-value"><%= dashModel.warning == 0 && dashModel.offline == 0 ? "정상" : "주의" %></div><small>총 <%= dashModel.total %>대 / 정상 <%= dashModel.normal %>대</small></div><div>›</div></a>
            <div class="panel kpi"><div class="kpi-icon" style="color:var(--dash-cyan);background:rgba(39,183,255,.15)">⌁</div><div><h3>전체 부하율</h3><div class="kpi-value blue"><%= h(fragmentModel.avgLoadText) %><span>%</span></div><small>최근 1시간 평균</small></div><svg class="mini-chart" viewBox="0 0 80 44"><polyline points="<%= h(fragmentModel.kpiLoadMiniPoints) %>" fill="none" stroke="#24e6ef" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <div class="panel kpi"><div class="kpi-icon">ϟ</div><div><h3>총 출력</h3><div class="kpi-value"><%= h(fragmentModel.powerSumText) %><span>kW</span></div><small>피상전력 <%= h(fragmentModel.apparentPowerSumText) %> kVA</small></div><div>›</div></div>
            <div class="panel kpi"><div class="kpi-icon">▣</div><div><h3>배터리 평균</h3><div class="kpi-value"><%= h(fragmentModel.avgBatteryText) %><span>%</span></div><small>최근 1시간 평균</small></div><svg class="mini-chart" viewBox="0 0 80 44"><%= fragmentModel.kpiBatteryMiniBars %></svg></div>
            <a class="panel kpi kpi-link" href="alarm/alarm_view.jsp?status=ACTIVE" title="UPS 알람 보기"><div class="kpi-icon" style="color:var(--dash-yellow);background:rgba(255,191,49,.15)">△</div><div><h3>UPS 알람</h3><div class="kpi-value yellow"><%= dashModel.activeAlarms %><span>건</span></div><small>미확인 알림</small></div><div>›</div></a>
        </section>


